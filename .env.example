# =========================
# NEMO CrudeFlow - Root Env
# =========================

# Frontend
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_API_WS_URL=/ws

# Backend
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/neondb?sslmode=require
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI Provider (Gemma/Gemini integration)
GEMINI_API_KEY=replace_with_api_key
GEMMA4_API_URL=https://openrouter.ai/api/v1/chat/completions
GEMMA4_MODEL=google/gemma-3-27b-it
GEMMA4_API_KEY=replace_with_api_key
GEMMA4_TIMEOUT_SECONDS=30

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

