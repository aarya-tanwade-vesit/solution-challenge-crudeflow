# CrudeFlow Frontend — Environment Variables Template
# Copy this to .env.local and update with your backend URLs

# ============================================
# Backend API Configuration
# ============================================

# REST API base URL
# For local rewrite proxy use /api/v1
NEXT_PUBLIC_API_URL=/api/v1

# WebSocket URL for real-time updates
NEXT_PUBLIC_API_WS_URL=/ws

# ============================================
# Authentication (optional)
# ============================================

# Auth provider: 'oauth2', 'api-key', or 'none'
NEXT_PUBLIC_AUTH_PROVIDER=oauth2

# OAuth2 provider URL (if using OIDC/OAuth2)
NEXT_PUBLIC_AUTH_URL=http://localhost:8000/auth

# JWT token storage key (optional)
# NEXT_PUBLIC_TOKEN_KEY=crudeflow_token

# ============================================
# Analytics & Monitoring (optional)
# ============================================

# Sentry error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Amplitude product analytics
# NEXT_PUBLIC_AMPLITUDE_KEY=xxx

# ============================================
# Third-Party APIs (optional)
# ============================================

# News aggregation API key (for geopolitical sentiment feed)
# NEXT_PUBLIC_NEWS_API_KEY=xxx

# Geopolitical sentiment analysis API
# NEXT_PUBLIC_SENTIMENT_API_URL=http://localhost:9000/api/sentiment

# ============================================
# Feature Flags (optional)
# ============================================

# Enable simulation mode UI
# NEXT_PUBLIC_ENABLE_SIMULATION=true

# Enable analytics dashboard
# NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Enable decision queue
# NEXT_PUBLIC_ENABLE_DECISIONS=true

# ============================================
# Development Settings (optional)
# ============================================

# Enable debug logging in components
# NEXT_PUBLIC_DEBUG=true

# Mock data mode (disable this to use real API)
# NEXT_PUBLIC_USE_MOCK_DATA=false

# ============================================
# Notes
# ============================================

# • Only environment variables prefixed with NEXT_PUBLIC_ are available in browser
# • For backend-only secrets, create regular .env variables (not NEXT_PUBLIC_)
# • Restart dev server after changing environment variables
# • For production, set these in your deployment platform (Vercel, Docker, etc.)
